{
  "name": "@pz4l/tinyimg-cli",
  "type": "module",
  "version": "0.1.1-beta.1",
  "description": "CLI tool for TinyPNG image compression with batch processing and interactive key management",
  "author": "pzehrel",
  "license": "MIT",
  "homepage": "https://github.com/pzehrel/tinyimg/tree/main/packages/tinyimg-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pzehrel/tinyimg.git",
    "directory": "packages/tinyimg-cli"
  },
  "bugs": {
    "url": "https://github.com/pzehrel/tinyimg/issues"
  },
  "keywords": [
    "tinypng",
    "image",
    "compression",
    "compress",
    "cli",
    "command-line",
    "optimize",
    "optimization",
    "img",
    "minify",
    "png",
    "jpg",
    "jpeg",
    "batch",
    "imagemin"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "bin": {
    "tinyimg": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@pz4l/tinyimg-core": "workspace:*",
    "cac": "^7.0.0",
    "fast-glob": "^3.3.3",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@clack/prompts": "^1.1.0"
  }
}
