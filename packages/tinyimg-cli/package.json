{
  "name": "tinyimg-cli",
  "type": "module",
  "version": "0.0.0",
  "description": "CLI tool for TinyPNG image compression with batch processing and interactive key management",
  "author": "pzehrel",
  "license": "MIT",
  "keywords": [
    "tinypng",
    "image",
    "compression",
    "compress",
    "cli",
    "command-line",
    "optimize",
    "optimization",
    "img",
    "minify",
    "png",
    "jpg",
    "jpeg",
    "batch",
    "imagemin"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "bin": {
    "tinyimg": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cac": "^7.0.0",
    "fast-glob": "^3.3.3",
    "kleur": "^4.1.5",
    "tinyimg-core": "workspace:*"
  },
  "devDependencies": {
    "@clack/prompts": "^1.1.0"
  }
}
