{
  "name": "tinyimg-core",
  "type": "module",
  "version": "0.0.0",
  "description": "Core library for TinyPNG image compression with multi-key management, intelligent caching, and fallback strategies",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "form-data": "4.0.5",
    "p-limit": "7.3.0",
    "tinify": "1.8.2"
  }
}
