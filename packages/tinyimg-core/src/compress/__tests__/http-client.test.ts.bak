    it('should throw on 5xx server errors', async () => {
      requestSpy.mockImplementation((url: any, options: any, callback: any) => {
        const mockRes = {
          statusCode: 500,
          on: vi.fn(),
        }

        callback(mockRes)

        setTimeout(() => {
          const listeners = mockRes.on.mock.calls
