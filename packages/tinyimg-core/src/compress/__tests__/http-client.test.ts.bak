              fn(mockCompressedBuffer)
            }
            else if (event === 'end') {
              fn()
            }
          })
        }, 0)

        return createMockClientRequest()
      })

      const result = await client.compress('test-api-key', mockInputBuffer)
      expect(result).toEqual(mockCompressedBuffer)
    })

