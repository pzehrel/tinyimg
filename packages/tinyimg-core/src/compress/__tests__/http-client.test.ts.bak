    it('should create SERVER_ERROR for 500', async () => {
      const mockInputBuffer = createMockPngBuffer(1024)

      requestSpy.mockImplementation((url: any, options: any, callback: any) => {
        const mockRes = {
          statusCode: 500,
          on: vi.fn(),
        }

        callback(mockRes)

