    "url": "git+https://github.com/pzehrel/tinyimg.git",
    "directory": "packages/tinyimg-unplugin"
  },
  "bugs": {
    "url": "https://github.com/pzehrel/tinyimg/issues"
  },
  "keywords": [
    "tinypng",
    "image",
    "compression",
    "compress",
