{
  "name": "@pz4l/tinyimg-vite",
  "type": "module",
  "version": "0.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/pzehrel/tinyimg.git",
    "directory": "packages/vite"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "test -n \"$CI\" || (echo 'Error: Publishing is only allowed from CI.' && exit 1)"
  },
  "peerDependencies": {
    "vite": "^5.0.0 || ^6.0.0"
  },
  "dependencies": {
    "p-limit": "^6.2.0",
    "pathe": "^2.0.3"
  },
  "devDependencies": {
    "@pz4l/tinyimg-core": "workspace:*",
    "@pz4l/tinyimg-locale": "workspace:*",
    "tsdown": "^0.21.8",
    "typescript": "^5.9.3",
    "vite": "^6.2.0"
  }
}
