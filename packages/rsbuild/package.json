{
  "name": "@pz4l/tinyimg-rsbuild",
  "type": "module",
  "version": "0.0.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "test -n \"$CI\" || (echo 'Error: Publishing is only allowed from CI.' && exit 1)"
  },
  "peerDependencies": {
    "@rsbuild/core": ">=1.0.0"
  },
  "dependencies": {
    "p-limit": "^6.2.0",
    "pathe": "^2.0.3"
  },
  "devDependencies": {
    "@pz4l/tinyimg-core": "workspace:*",
    "@pz4l/tinyimg-locale": "workspace:*",
    "@rsbuild/core": "^1.3.5",
    "tsdown": "^0.21.8",
    "typescript": "^5.9.3"
  }
}
