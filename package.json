{
  "name": "tinyimg-monorepo",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "description": "TinyPNG image compression tool with multi-architecture support",
  "author": "pzehrel",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
