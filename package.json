{
  "name": "tinyimg-monorepo",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "description": "TinyPNG image compression tool with multi-architecture support",
  "author": "pzehrel",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "echo 'See individual packages'",
    "build": "pnpm -r --filter './packages/**' build",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:coverage": "vitest --coverage",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "devDependencies": {
    "@antfu/eslint-config": "7.7.3",
    "@changesets/cli": "2.30.0",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "latest",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "eslint": "9.x",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsdown": "0.21.4",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  }
}
