{
  "name": "tinyimg-monorepo",
  "type": "module",
  "version": "0.3.6",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "description": "TinyPNG image compression tool with multi-architecture support",
  "author": "pzehrel",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "echo 'See individual packages'",
    "build": "pnpm -r --filter './packages/**' build",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:coverage": "vitest --coverage",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepublishOnly": "test -n \"$CI\" || (echo \"Error: Publishing is only allowed from CI. Use the release workflow instead.\" && exit 1)",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.0.0",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
